# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (never expose to the client). Used by admin/server tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- DB migrate scripts (scripts/db/*) ---
# Supabase → Project Settings → Database → Connection string
# Prefer "Direct connection" / Session mode (port 5432), NOT Transaction pooler (6543).
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres
#
# Future self-hosted / VPS Postgres:
# TARGET_DB_URL=postgresql://app:password@your-server:5432/desireprive
